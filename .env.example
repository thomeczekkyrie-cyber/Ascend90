# ================================================
# ASCEND90 — Environment Variables
# Copy this to .env and fill in your values
# ================================================

# Supabase (get from: supabase.com > your project > Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # for webhook only — keep secret

# Stripe (get from: dashboard.stripe.com > Developers > API keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_PRICE_ID=price_your_monthly_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App URL (your Vercel domain)
NEXT_PUBLIC_APP_URL=https://ascend90.vercel.app
